@@ -82,6 +82,19 @@ os.makedirs("logs", exist_ok=True)
 MODEL_DIR   = f"models/{EXP_NAME}"
 FINAL_MODEL = os.path.join(MODEL_DIR, f"cellpose_{EXP_NAME}")
 
+# Fall back to the latest epoch-suffixed checkpoint if the final model hasn't
+# been written yet — useful for inference mid-training.
+if not os.path.exists(FINAL_MODEL):
+    import glob, re
+    candidates = glob.glob(os.path.join(MODEL_DIR, f"cellpose_{EXP_NAME}_ep*"))
+    def _ep(path: str) -> int:
+        m = re.search(r"_ep(\d+)$", path)
+        return int(m.group(1)) if m else -1
+    candidates = sorted([c for c in candidates if _ep(c) >= 0], key=_ep)
+    if candidates:
+        FINAL_MODEL = candidates[-1]
+        print(f"Canonical checkpoint missing, using latest epoch: {FINAL_MODEL}")
+
 if os.path.exists(FINAL_MODEL):
     print(f"Loading fine-tuned model: {FINAL_MODEL}")
     seg_model = cp_models.CellposeModel(gpu=True, pretrained_model=FINAL_MODEL)
